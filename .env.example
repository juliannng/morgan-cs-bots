# Copy to .env and fill in real values. .env is gitignored.

# --- Google Cloud / Vertex AI ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# --- Tavily (scholarship bot web search) ---
# Free tier: 1000 searches/month. Get key at https://app.tavily.com
TAVILY_API_KEY=tvly-...

# --- Canvas LMS (tutor bot) ---
# Generate a personal access token: Canvas -> Account -> Settings -> New Access Token
CANVAS_API_TOKEN=
CANVAS_BASE_URL=https://canvas.instructure.com

# --- Optional: Vertex AI Search datastores (tutor) ---
# If set, course material search works. Leave blank to skip.
VERTEX_AI_DATASTORE_ID=
SYLLABI_DATASTORE_ID=

# --- Optional: GCS bucket for Canvas file sync (tutor) ---
GCS_BUCKET=
